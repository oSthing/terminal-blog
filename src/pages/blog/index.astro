---
import BaseLayout from '@layouts/BaseLayout.astro';
import PostCard from '@components/PostCard.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
---

<BaseLayout title="blog" description={`${SITE.title} — all posts`}>
  <section class="mx-auto w-full max-w-3xl px-6 py-16">
    <header class="mb-12">
      <p class="font-mono text-xs uppercase tracking-wider text-muted-light dark:text-muted-dark">
        index
      </p>
      <h1 class="mt-2 text-4xl font-semibold tracking-tight">blog</h1>
      <p class="mt-3 text-muted-light dark:text-muted-dark">
        {posts.length} {posts.length === 1 ? 'post' : 'posts'} on cryptography, systems, and software craft.
      </p>
    </header>

    {
      posts.length === 0 ? (
        <p class="text-muted-light dark:text-muted-dark">No posts yet.</p>
      ) : (
        <div class="grid gap-4">
          {posts.map((entry) => <PostCard entry={entry} />)}
        </div>
      )
    }
  </section>
</BaseLayout>
