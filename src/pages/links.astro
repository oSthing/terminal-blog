---
import BaseLayout from '@layouts/BaseLayout.astro';
import { friends } from '../data/friends';
import { SITE } from '../consts';
---

<BaseLayout title="links" description={`${SITE.title} — friend links`}>
  <section class="mx-auto w-full max-w-3xl px-6 py-16">
    <header class="mb-12">
      <p class="font-mono text-xs uppercase tracking-wider text-muted-light dark:text-muted-dark">
        /links
      </p>
      <h1 class="mt-2 text-4xl font-semibold tracking-tight">links</h1>
      <p class="mt-3 text-muted-light dark:text-muted-dark">
        friends and sites i read. want to exchange links? <a href="/contact" class="hover:underline">say hi</a>.
      </p>
    </header>

    {
      friends.length === 0 ? (
        <p class="text-muted-light dark:text-muted-dark">no links yet.</p>
      ) : (
        <ul class="divide-y divide-border-light dark:divide-border-dark border-y border-border-light dark:border-border-dark">
          {friends.map((friend) => (
            <li class="py-6">
              <div class="flex items-baseline justify-between gap-4">
                <h2 class="text-lg font-semibold tracking-tight">
                  <a href={friend.url} class="hover:underline" rel="noopener noreferrer" target="_blank">
                    {friend.name}
                  </a>
                </h2>
                {friend.tags && friend.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1.5">
                    {friend.tags.map((tag) => (
                      <span class="rounded-full border border-border-light dark:border-border-dark px-2 py-0.5 text-xs">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>
              <p class="mt-2 text-muted-light dark:text-muted-dark">{friend.description}</p>
              <p class="mt-2 break-all font-mono text-xs text-muted-light dark:text-muted-dark">{friend.url}</p>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>
