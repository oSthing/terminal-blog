---
import '@styles/global.css';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import ThemeScript from '@components/ThemeScript.astro';
import { SITE } from '../consts';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  showTerminal?: boolean;
}

const {
  title,
  description = SITE.description,
  ogImage,
  noindex = false,
  showTerminal = false,
} = Astro.props;

const pageTitle = title ? `${title} — ${SITE.title}` : SITE.title;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage ?? '/og-default.png', Astro.site).toString();
---

<!doctype html>
<html lang={SITE.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL.toString()} />
    <link rel="alternate" type="application/rss+xml" title={SITE.title} href="/rss.xml" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.toString()} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:locale" content={SITE.locale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/JetBrains/JetBrainsMono@v2.304/web/css/jetbrains-mono.css"
    />
  </head>
  <body class="min-h-screen flex flex-col bg-bg-light dark:bg-bg-dark text-fg-light dark:text-fg-dark antialiased">
    <ThemeScript />
    <Header showTerminalLink={showTerminal} />

    <main class="flex-1 w-full">
      <slot />
    </main>

    <Footer />
  </body>
</html>
