---
import { type CollectionEntry } from 'astro:content';
import { SITE } from '../consts';

interface Props {
  entry: CollectionEntry<'blog'>;
}

const { entry } = Astro.props;
const { data, slug } = entry;
const dateFormatted = data.pubDate.toLocaleDateString(SITE.locale, {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a
  href={`/blog/${slug}`}
  class="group block rounded-lg border border-border-light dark:border-border-dark p-5 transition-colors hover:border-fg-light dark:hover:border-fg-dark"
>
  <div class="flex items-center justify-between text-xs text-muted-light dark:text-muted-dark">
    <time datetime={data.pubDate.toISOString()}>{dateFormatted}</time>
    <span class="font-mono">{slug}</span>
  </div>
  <h3 class="mt-3 text-lg font-semibold tracking-tight group-hover:underline">
    {data.title}
  </h3>
  <p class="mt-2 text-sm text-muted-light dark:text-muted-dark line-clamp-2">{data.description}</p>
  {
    data.tags.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-1.5">
        {data.tags.slice(0, 4).map((tag) => (
          <span class="rounded-full border border-border-light dark:border-border-dark px-2 py-0.5 text-xs">
            {tag}
          </span>
        ))}
      </div>
    )
  }
</a>
